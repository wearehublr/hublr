# Used to build absolute URLs for the sitemap and page metadata.
NEXT_PUBLIC_SITE_URL=https://wearehublr.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The one account allowed into /admin. Must match the email of the user you
# created manually in Supabase Authentication > Users.
ADMIN_EMAIL=you@example.com

# Shown on /book. Swap this for your own scheduling link any time.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/murielltokam

# Sends an email to ADMIN_EMAIL whenever the Work With Us form is submitted.
# Get a key from resend.com (free tier). Leave unset to skip emailing.
RESEND_API_KEY=re_your_api_key

# Google Analytics measurement ID (from analytics.google.com). Leave unset
# to skip Google Analytics — Vercel Analytics works independently of this.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
